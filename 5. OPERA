# parrelell jobs submission
#=========================================================================#
opera="/public/home/gaikai/opera_Linux/opera_Linux"
bfile="/public/home/gaikai/Age/data/g1000_eur/g1000_eur"
besd="/public/home/gaikai/Age/data/opera/new/root.txt"
GWASDIRT='/public/home/gaikai/Age/data/GWAS/'
PHENO=(""  "Hannum" "IEAA" "PhenoAge" "GrimAge" "Multivariate")
GWASDATA=("" "Hannum_EUR_summary_statistics1.txt" "IEAA_EUR_summary_statistics1.txt" "PhenoAge_EUR_summary_statistics1.txt" "GrimAge_EUR_summary_statistics1.txt" "Multivariate_EUR_summary_statistics1.txt")
NPHENO=$(($(echo ${#PHENO[@]}) - 1 ))
OUTPUT="/public/home/gaikai/Age/data/opera/new/"

#	stage 1; run jobs by phenotype.
for((p=1;p<=${NPHENO};p++))
do
cmd="${opera} --besd-flist ${besd} \
 --gwas-summary ${GWASDIRT}${GWASDATA[$p]} \
 --bfile ${bfile} \
 --estimate-pi \
 --out ${OUTPUT}${PHENO[$p]}_opera --thread-num 3 \
 > ${OUTPUT}${PHENO[$p]}_opera.log 2>&1"
qsubshcom "$cmd" 3 40G opera${p} 10:00:00 ""
done

#	stage 2  low threshold
for((p=1;p<=${NPHENO};p++))
do
cmd="${opera} --besd-flist ${besd} \
 --gwas-summary ${GWASDIRT}${GWASDATA[$p]} \
 --bfile ${bfile} \
 --prior-pi-file ${OUTPUT}${PHENO[$p]}_opera.pi \
 --prior-var-file ${OUTPUT}${PHENO[$p]}_opera.var \
 --thresh-heidi 1.00e-03 \
 --thresh-ppa 8.00e-01 \
 --out ${OUTPUT}${PHENO[$p]}_opera_stage2 --thread-num 10 \
 > ${OUTPUT}${PHENO[$p]}_opera_stage2.log 2>&1"
qsubshcom "$cmd" 10 60G opere${p} 15:00:00 ""
done

